			</Loads>
		</step>
	</Step>
	<LoadData>
		<load_controller id="1" name="lift_ramp" type="loadcurve">
			<interpolate>LINEAR</interpolate>
			<extend>CONSTANT</extend>
			<points>
				<pt>0,0</pt>
				<pt>1,0</pt>
				<pt>2,1</pt>
				<pt>5,1</pt>
			</points>
		</load_controller>
		<load_controller id="2" name="inward_ramp" type="loadcurve">
			<interpolate>LINEAR</interpolate>
			<extend>CONSTANT</extend>
			<points>
				<pt>0,0</pt>
				<pt>3,0</pt>
				<pt>4,1</pt>
				<pt>5,1</pt>
			</points>
		</load_controller>
		<load_controller id="3" name="suction_pressure_curve" type="loadcurve">
			<interpolate>LINEAR</interpolate>
			<extend>CONSTANT</extend>
			<points>
				<pt>0,0</pt>
				<pt>1,1</pt>
				<pt>2,1</pt>
				<pt>5,1</pt>
			</points>
		</load_controller>
	</LoadData>
	<Output>
		<plotfile type="febio">
			<var type="displacement"/>
			<var type="stress"/>
			<var type="contact force"/>
			<var type="reaction forces"/>
			<var type="contact traction" surface="nucleus_interface_left_surface"/>
			<var type="contact traction" surface="nucleus_interface_right_surface"/>
			<var type="contact traction" surface="nucleus_interface_top_surface"/>
			<var type="contact traction" surface="nucleus_interface_bottom_surface"/>
			<var type="contact traction" surface="cell_dish_left_surface"/>
			<var type="contact traction" surface="cell_dish_center_surface"/>
			<var type="contact traction" surface="cell_dish_right_surface"/>
		</plotfile>
		<logfile>
			<node_data data="ux;uy;uz" file="febio_nucleus_nodes.csv" node_set="nodeset20"/>
			<node_data data="ux;uy;uz" file="febio_cytoplasm_nodes.csv" node_set="nodeset21"/>
			<node_data data="ux;uy;uz" file="febio_pipette_contact_nodes.csv" node_set="nodeset22"/>
			<rigid_body_data data="x;y;z;Fx;Fy;Fz"/>
			<face_data data="contact gap;contact pressure" file="febio_interface_nucleus_cytoplasm.csv" surface="nucleus_interface_surface"/>
			<face_data data="contact gap;contact pressure" file="febio_interface_nc_left.csv" surface="nucleus_interface_left_surface"/>
			<face_data data="contact gap;contact pressure" file="febio_interface_nc_right.csv" surface="nucleus_interface_right_surface"/>
			<face_data data="contact gap;contact pressure" file="febio_interface_nc_top.csv" surface="nucleus_interface_top_surface"/>
			<face_data data="contact gap;contact pressure" file="febio_interface_nc_bottom.csv" surface="nucleus_interface_bottom_surface"/>
			<face_data data="contact gap;contact pressure" file="febio_interface_cell_dish.csv" surface="cell_dish_surface"/>
			<face_data data="contact gap;contact pressure" file="febio_interface_cd_left.csv" surface="cell_dish_left_surface"/>
			<face_data data="contact gap;contact pressure" file="febio_interface_cd_center.csv" surface="cell_dish_center_surface"/>
			<face_data data="contact gap;contact pressure" file="febio_interface_cd_right.csv" surface="cell_dish_right_surface"/>
			<face_data data="contact gap;contact pressure" file="febio_pipette_cell_contact.csv" surface="pipette_suction_surface"/>
			<face_data data="contact gap;contact pressure" file="febio_pipette_contact.csv" surface="pipette_contact_surface"/>
		</logfile>
	</Output>
</febio_spec>
