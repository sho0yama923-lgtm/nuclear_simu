					<shell_bottom>0</shell_bottom>
				</surface_load>
			</Loads>
		</step>
		<step id="3" name="Step03">
			<Control>
				<analysis>STATIC</analysis>
				<time_steps>60</time_steps>
				<step_size>0.016667</step_size>
				<plot_zero_state>0</plot_zero_state>
				<plot_range>0,-1</plot_range>
				<plot_level>PLOT_MAJOR_ITRS</plot_level>
				<output_level>OUTPUT_MAJOR_ITRS</output_level>
				<plot_stride>1</plot_stride>
				<output_stride>1</output_stride>
				<adaptor_re_solve>1</adaptor_re_solve>
				<solver type="solid">
					<symmetric_stiffness>non-symmetric</symmetric_stiffness>
					<equation_scheme>staggered</equation_scheme>
					<equation_order>default</equation_order>
					<optimize_bw>0</optimize_bw>
					<lstol>0.9</lstol>
					<lsmin>0.01</lsmin>
					<lsiter>5</lsiter>
					<ls_check_jacobians>0</ls_check_jacobians>
					<max_refs>15</max_refs>
					<check_zero_diagonal>0</check_zero_diagonal>
					<zero_diagonal_tol>0</zero_diagonal_tol>
					<force_partition>0</force_partition>
					<reform_each_time_step>1</reform_each_time_step>
					<reform_augment>0</reform_augment>
					<diverge_reform>1</diverge_reform>
					<min_residual>1e-20</min_residual>
					<max_residual>0</max_residual>
					<dtol>0.001</dtol>
					<etol>0.01</etol>
					<rtol>0</rtol>
					<rhoi>-2</rhoi>
					<alpha>1</alpha>
					<beta>0.25</beta>
					<gamma>0.5</gamma>
					<logSolve>0</logSolve>
					<arc_length>0</arc_length>
					<arc_length_scale>0</arc_length_scale>
				</solver>
			</Control>
			<Rigid>
				<rigid_bc name="RigidConstraint6" type="rigid_displacement">
					<rb>pipette_rigid</rb>
					<dof>x</dof>
					<value>0</value>
					<relative>1</relative>
				</rigid_bc>
				<rigid_bc name="RigidConstraint7" type="rigid_displacement">
					<rb>pipette_rigid</rb>
					<dof>z</dof>
					<value lc="1">8</value>
					<relative>1</relative>
				</rigid_bc>
			</Rigid>
			<Loads>
				<surface_load name="pipette_suction_pressure_lift" surface="pipette_suction_surface" type="pressure">
					<pressure lc="3">-0.7</pressure>
					<symmetric_stiffness>1</symmetric_stiffness>
					<linear>0</linear>
					<shell_bottom>0</shell_bottom>
				</surface_load>
			</Loads>
		</step>
		<step id="4" name="Step04">
			<Control>
				<analysis>STATIC</analysis>
				<time_steps>90</time_steps>
				<step_size>0.011111</step_size>
				<plot_zero_state>0</plot_zero_state>
				<plot_range>0,-1</plot_range>
				<plot_level>PLOT_MAJOR_ITRS</plot_level>
				<output_level>OUTPUT_MAJOR_ITRS</output_level>
				<plot_stride>1</plot_stride>
				<output_stride>1</output_stride>
				<adaptor_re_solve>1</adaptor_re_solve>
				<solver type="solid">
					<symmetric_stiffness>non-symmetric</symmetric_stiffness>
					<equation_scheme>staggered</equation_scheme>
					<equation_order>default</equation_order>
					<optimize_bw>0</optimize_bw>
					<lstol>0.9</lstol>
					<lsmin>0.01</lsmin>
					<lsiter>5</lsiter>
					<ls_check_jacobians>0</ls_check_jacobians>
					<max_refs>15</max_refs>
					<check_zero_diagonal>0</check_zero_diagonal>
					<zero_diagonal_tol>0</zero_diagonal_tol>
					<force_partition>0</force_partition>
					<reform_each_time_step>1</reform_each_time_step>
					<reform_augment>0</reform_augment>
					<diverge_reform>1</diverge_reform>
					<min_residual>1e-20</min_residual>
					<max_residual>0</max_residual>
					<dtol>0.001</dtol>
					<etol>0.01</etol>
					<rtol>0</rtol>
					<rhoi>-2</rhoi>
					<alpha>1</alpha>
					<beta>0.25</beta>
					<gamma>0.5</gamma>
					<logSolve>0</logSolve>
					<arc_length>0</arc_length>
					<arc_length_scale>0</arc_length_scale>
				</solver>
			</Control>
			<Rigid>
				<rigid_bc name="RigidConstraint8" type="rigid_displacement">
					<rb>pipette_rigid</rb>
					<dof>x</dof>
					<value lc="2">-1.8</value>
					<relative>1</relative>
				</rigid_bc>
				<rigid_bc name="RigidConstraint9" type="rigid_displacement">
					<rb>pipette_rigid</rb>
					<dof>z</dof>
