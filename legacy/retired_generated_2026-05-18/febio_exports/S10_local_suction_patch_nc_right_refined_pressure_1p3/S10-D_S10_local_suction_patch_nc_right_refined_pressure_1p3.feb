  <MeshDomains>
    <SolidDomain name="nucleus" mat="nucleus" />
    <SolidDomain name="cytoplasm" mat="cytoplasm" />
    <SolidDomain name="dish" mat="dish" />
    <SolidDomain name="pipette" mat="pipette_rigid" />
  </MeshDomains>
  <Boundary>
    <bc name="dish_fixed" node_set="dish_fixed_nodes" type="zero displacement">
      <x_dof>1</x_dof>
      <y_dof>1</y_dof>
      <z_dof>1</z_dof>
    </bc>
    <bc name="section_plane_lock" node_set="deformable_nodes_set" type="zero displacement">
      <y_dof>1</y_dof>
    </bc>
  </Boundary>
  <Contact>
    <contact name="nucleus_cytoplasm_left_interface" type="tied-elastic" surface_pair="nucleus_cytoplasm_left_pair">
      <!-- solver-primary force-transfer coupling; cohesive law deferred -->
      <penalty>1.147500</penalty>
      <tolerance>0.180000</tolerance>
      <!-- requestedType=tied-elastic criticalNormalStress=0.780000 criticalShearStress=0.580000 fractureEnergy=0.280000 -->
    </contact>
    <contact name="nucleus_cytoplasm_right_interface" type="tied-elastic" surface_pair="nucleus_cytoplasm_right_pair">
      <!-- solver-primary force-transfer coupling; cohesive law deferred -->
      <penalty>1.147500</penalty>
      <tolerance>0.180000</tolerance>
      <!-- requestedType=tied-elastic criticalNormalStress=0.780000 criticalShearStress=0.580000 fractureEnergy=0.280000 -->
    </contact>
    <contact name="cell_dish_interface" type="tied-elastic" surface_pair="cell_dish_pair">
      <penalty>15.500000</penalty>
      <tolerance>0.050000</tolerance>
      <!-- cohesive-ready normalStiffness=15.500000 tangentialStiffness=1.250000 -->
      <!-- cohesive-ready criticalNormalStress=0.950000 criticalShearStress=0.650000 fractureEnergy=0.350000 -->
    </contact>
    <!-- pipette_nucleus_contact omitted: status=omitted after shared-node nucleus-cytoplasm coupling; pipette-cell pressure/contact remains solver-active reason=shared-node force transfer removed the stabilizer requirement -->
    <contact name="pipette_cell_contact" type="sliding-elastic" surface_pair="pipette_cell_pair">
      <penalty>6.975000</penalty>
      <auto_penalty>1</auto_penalty>
      <two_pass>0</two_pass>
      <laugon>0</laugon>
      <tolerance>0.200000</tolerance>
      <search_tol>2.640000</search_tol>
      <search_radius>16.250000</search_radius>
      <symmetric_stiffness>0</symmetric_stiffness>
      <fric_coeff>0.091000</fric_coeff>
      <!-- status=solver-active secondary contact mode=secondary-contact-proxy -->
    </contact>
  </Contact>
  <Rigid>
    <rigid_bc type="rigid_fixed">
      <rb>pipette_rigid</rb>
      <Ry_dof>1</Ry_dof>
      <Ru_dof>1</Ru_dof>
      <Rv_dof>1</Rv_dof>
      <Rw_dof>1</Rw_dof>
    </rigid_bc>
  </Rigid>
  <Loads>
    <!-- nodal_load hold_force_proxy surface=pipette_contact_surface lc=201 status=proxy-load / not pressure-driven value=20.000000 -->
    <surface_load name="pipette_suction_pressure" surface="pipette_suction_patch" type="pressure">
      <pressure lc="3">-1.300000</pressure>
      <!-- status=solver-active pressure-driven suction / native-only unit=kPa direction=inward-negative-pressure magnitude=1.300000 -->
    </surface_load>
    <surface_load name="cell_dish_normal_preload" surface="cell_dish_surface" type="pressure">
      <pressure lc="4">0.100000</pressure>
      <!-- status=solver-active bounded normal-preload comparison / native-only unit=kPa direction=cell-dish-normal-preload; positive pressure on -z basal cell surface pushes toward dish magnitude=0.100000 -->
    </surface_load>
  </Loads>
  <LoadData>
    <load_controller id="1" name="lift_ramp" type="loadcurve">
      <interpolate>LINEAR</interpolate>
      <extend>CONSTANT</extend>
      <points>
        <point>0.000000, 0.000000</point>
        <point>2.000000, 0.000000</point>
        <point>3.000000, 1.000000</point>
        <point>5.000000, 1.000000</point>
      </points>
    </load_controller>
    <load_controller id="2" name="inward_ramp" type="loadcurve">
      <interpolate>LINEAR</interpolate>
      <extend>CONSTANT</extend>
      <points>
        <point>0.000000, 0.000000</point>
        <point>3.000000, 0.000000</point>
        <point>4.000000, 1.000000</point>
        <point>5.000000, 1.000000</point>
      </points>
    </load_controller>
    <load_controller id="3" name="suction_pressure_curve" type="loadcurve">
      <interpolate>LINEAR</interpolate>
      <extend>CONSTANT</extend>
      <points>
        <point>0.000000, 0.000000</point>
        <point>1.000000, 1.000000</point>
        <point>2.000000, 1.000000</point>
        <point>5.000000, 1.000000</point>
      </points>
    </load_controller>
    <load_controller id="4" name="cell_dish_normal_preload_curve" type="loadcurve">
      <interpolate>LINEAR</interpolate>
      <extend>CONSTANT</extend>
      <points>
        <point>0.000000, 0.000000</point>
        <point>1.000000, 1.000000</point>
        <point>5.000000, 1.000000</point>
      </points>
    </load_controller>
  </LoadData>
  <Step>
    <step id="1" name="approach">
    <Control>
      <analysis>static</analysis>
      <time_steps>60</time_steps>
      <step_size>0.016667</step_size>
      <plot_level>PLOT_MAJOR_ITRS</plot_level>
      <output_level>OUTPUT_MAJOR_ITRS</output_level>
      <solver>
        <symmetric_stiffness>0</symmetric_stiffness>
      </solver>
    </Control>
    <Rigid>
      <rigid_bc type="rigid_displacement">
        <rb>pipette_rigid</rb>
        <dof>x</dof>
        <value>0.000000</value>
        <relative>1</relative>
      </rigid_bc>
      <rigid_bc type="rigid_displacement">
        <rb>pipette_rigid</rb>
        <dof>z</dof>
        <value>-0.350000</value>
        <relative>1</relative>
      </rigid_bc>
    </Rigid>
    </step>
    <step id="2" name="hold">
    <Control>
      <analysis>static</analysis>
      <time_steps>1</time_steps>
      <step_size>1.000000</step_size>
      <plot_level>PLOT_MAJOR_ITRS</plot_level>
      <output_level>OUTPUT_MAJOR_ITRS</output_level>
      <solver>
        <symmetric_stiffness>0</symmetric_stiffness>
      </solver>
    </Control>
    <Rigid>
      <rigid_bc type="rigid_displacement">
        <rb>pipette_rigid</rb>
        <dof>x</dof>
        <value>0.000000</value>
        <relative>1</relative>
      </rigid_bc>
      <rigid_bc type="rigid_displacement">
        <rb>pipette_rigid</rb>
        <dof>z</dof>
        <value>0.000000</value>
        <relative>1</relative>
      </rigid_bc>
    </Rigid>
    <Loads>
      <surface_load name="pipette_suction_pressure_hold" surface="pipette_suction_patch" type="pressure">
        <pressure lc="3">-1.300000</pressure>
        <!-- active-step pressure source=pipette_suction_pressure status=solver-active pressure-driven suction / native-only -->
      </surface_load>
      <surface_load name="cell_dish_normal_preload_hold" surface="cell_dish_surface" type="pressure">
        <pressure lc="4">0.100000</pressure>
        <!-- active-step pressure source=cell_dish_normal_preload status=solver-active bounded normal-preload comparison / native-only -->
      </surface_load>
    </Loads>
    </step>
    <step id="3" name="lift">
    <Control>
      <analysis>static</analysis>
      <time_steps>60</time_steps>
      <step_size>0.016667</step_size>
      <plot_level>PLOT_MAJOR_ITRS</plot_level>
      <output_level>OUTPUT_MAJOR_ITRS</output_level>
      <solver>
        <symmetric_stiffness>0</symmetric_stiffness>
      </solver>
    </Control>
    <Rigid>
      <rigid_bc type="rigid_displacement">
        <rb>pipette_rigid</rb>
        <dof>x</dof>
        <value>0.000000</value>
        <relative>1</relative>
      </rigid_bc>
      <rigid_bc type="rigid_displacement">
        <rb>pipette_rigid</rb>
        <dof>z</dof>
        <value lc="1">1.000000</value>
        <relative>1</relative>
      </rigid_bc>
    </Rigid>
    <Loads>
      <surface_load name="pipette_suction_pressure_lift" surface="pipette_suction_patch" type="pressure">
        <pressure lc="3">-1.300000</pressure>
        <!-- active-step pressure source=pipette_suction_pressure status=solver-active pressure-driven suction / native-only -->
      </surface_load>
      <surface_load name="cell_dish_normal_preload_lift" surface="cell_dish_surface" type="pressure">
        <pressure lc="4">0.100000</pressure>
        <!-- active-step pressure source=cell_dish_normal_preload status=solver-active bounded normal-preload comparison / native-only -->
      </surface_load>
    </Loads>
    </step>
    <step id="4" name="manipulation-1">
    <Control>
      <analysis>static</analysis>
      <time_steps>90</time_steps>
      <step_size>0.011111</step_size>
      <plot_level>PLOT_MAJOR_ITRS</plot_level>
      <output_level>OUTPUT_MAJOR_ITRS</output_level>
      <solver>
        <symmetric_stiffness>0</symmetric_stiffness>
      </solver>
    </Control>
    <Rigid>
      <rigid_bc type="rigid_displacement">
        <rb>pipette_rigid</rb>
        <dof>x</dof>
        <value lc="2">-0.112500</value>
        <relative>1</relative>
      </rigid_bc>
      <rigid_bc type="rigid_displacement">
        <rb>pipette_rigid</rb>
        <dof>z</dof>
        <value>0.000000</value>
        <relative>1</relative>
      </rigid_bc>
    </Rigid>
    <Loads>
      <surface_load name="pipette_suction_pressure_manipulation-1" surface="pipette_suction_patch" type="pressure">
        <pressure lc="3">-1.300000</pressure>
        <!-- active-step pressure source=pipette_suction_pressure status=solver-active pressure-driven suction / native-only -->
      </surface_load>
      <surface_load name="cell_dish_normal_preload_manipulation-1" surface="cell_dish_surface" type="pressure">
        <pressure lc="4">0.100000</pressure>
        <!-- active-step pressure source=cell_dish_normal_preload status=solver-active bounded normal-preload comparison / native-only -->
      </surface_load>
    </Loads>
    </step>
    <step id="5" name="manipulation-2">
    <Control>
      <analysis>static</analysis>
      <time_steps>1</time_steps>
      <step_size>1.000000</step_size>
      <plot_level>PLOT_MAJOR_ITRS</plot_level>
      <output_level>OUTPUT_MAJOR_ITRS</output_level>
      <solver>
        <symmetric_stiffness>0</symmetric_stiffness>
      </solver>
    </Control>
    <Rigid>
      <rigid_bc type="rigid_displacement">
        <rb>pipette_rigid</rb>
        <dof>x</dof>
        <value lc="2">-0.137500</value>
        <relative>1</relative>
      </rigid_bc>
      <rigid_bc type="rigid_displacement">
        <rb>pipette_rigid</rb>
        <dof>z</dof>
        <value>0.000000</value>
        <relative>1</relative>
      </rigid_bc>
    </Rigid>
    <Loads>
      <surface_load name="pipette_suction_pressure_manipulation-2" surface="pipette_suction_patch" type="pressure">
        <pressure lc="3">-1.300000</pressure>
        <!-- active-step pressure source=pipette_suction_pressure status=solver-active pressure-driven suction / native-only -->
      </surface_load>
      <surface_load name="cell_dish_normal_preload_manipulation-2" surface="cell_dish_surface" type="pressure">
        <pressure lc="4">0.100000</pressure>
        <!-- active-step pressure source=cell_dish_normal_preload status=solver-active bounded normal-preload comparison / native-only -->
      </surface_load>
    </Loads>
    </step>
  </Step>
  <Output>
    <logfile>
      <node_data name="nucleus_nodes" file="febio_nucleus_nodes.csv" data="ux;uy;uz" delim="," node_set="nucleus" />
      <node_data name="cytoplasm_nodes" file="febio_cytoplasm_nodes.csv" data="ux;uy;uz" delim="," node_set="cytoplasm_nodes" />
      <node_data name="pipette_suction_nodes" file="febio_pipette_suction_nodes.csv" data="ux;uy;uz" delim="," node_set="pipette_suction_nodes" />
      <node_data name="pipette_suction_patch_nodes" file="febio_pipette_suction_patch_nodes.csv" data="ux;uy;uz" delim="," node_set="pipette_suction_patch_nodes" />
      <node_data name="pipette_contact_nodes" file="febio_pipette_contact_nodes.csv" data="ux;uy;uz" delim="," node_set="pipette_contact_nodes" />
      <node_data name="nc_left_nucleus_nodes" file="febio_nc_left_nucleus_nodes.csv" data="ux;uy;uz" delim="," node_set="nc_left_nucleus_nodes" />
      <node_data name="nc_left_cytoplasm_nodes" file="febio_nc_left_cytoplasm_nodes.csv" data="ux;uy;uz" delim="," node_set="nc_left_cytoplasm_nodes" />
      <node_data name="nc_right_nucleus_nodes" file="febio_nc_right_nucleus_nodes.csv" data="ux;uy;uz" delim="," node_set="nc_right_nucleus_nodes" />
      <node_data name="nc_right_cytoplasm_nodes" file="febio_nc_right_cytoplasm_nodes.csv" data="ux;uy;uz" delim="," node_set="nc_right_cytoplasm_nodes" />
      <node_data name="nc_top_nucleus_nodes" file="febio_nc_top_nucleus_nodes.csv" data="ux;uy;uz" delim="," node_set="nc_top_nucleus_nodes" />
      <node_data name="nc_top_cytoplasm_nodes" file="febio_nc_top_cytoplasm_nodes.csv" data="ux;uy;uz" delim="," node_set="nc_top_cytoplasm_nodes" />
      <node_data name="nc_bottom_nucleus_nodes" file="febio_nc_bottom_nucleus_nodes.csv" data="ux;uy;uz" delim="," node_set="nc_bottom_nucleus_nodes" />
      <node_data name="nc_bottom_cytoplasm_nodes" file="febio_nc_bottom_cytoplasm_nodes.csv" data="ux;uy;uz" delim="," node_set="nc_bottom_cytoplasm_nodes" />
      <rigid_body_data name="pipette_rigid_body" file="febio_rigid_pipette.csv" data="x;y;z;Fx;Fy;Fz" delim=",">4</rigid_body_data>
      <face_data name="nucleus_cytoplasm_left_surface" file="febio_interface_nc_left.csv" data="contact gap;contact pressure" delim="," surface="nucleus_interface_left_surface" />
      <face_data name="nucleus_cytoplasm_right_surface" file="febio_interface_nc_right.csv" data="contact gap;contact pressure" delim="," surface="nucleus_interface_right_surface" />
      <face_data name="cell_dish_interface_surface" file="febio_interface_cell_dish.csv" data="contact gap;contact pressure" delim="," surface="cell_dish_surface" />
      <face_data name="pipette_cell_contact_surface" file="febio_pipette_cell_contact.csv" data="contact gap;contact pressure" delim="," surface="pipette_suction_patch" />
      <face_data name="pipette_contact_surface" file="febio_pipette_contact.csv" data="contact gap;contact pressure" delim="," surface="pipette_contact_surface" />
      <!-- derived_data name="pipette_aspiration_length" metric="L(t)" unit="um" payload="aspiration.length" source="native-node-displacement" -->
    </logfile>
    <plotfile type="febio">
      <var type="displacement" />
      <var type="stress" />
      <var type="contact force" />
      <var type="reaction forces" />
      <var type="contact traction" surface="nucleus_interface_left_surface"/>
      <var type="contact traction" surface="nucleus_interface_right_surface"/>
    </plotfile>
  </Output>
  <!-- native-only cohesive discrete sidecar (not solver-active yet) -->
</febio_spec>